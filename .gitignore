# ===============================
# GLPI Control Center - .gitignore
# ===============================

# -------------------------------
# 🔐 Variáveis sensíveis (TOKENS)
# -------------------------------

# Arquivo real de ambiente (NÃO subir)
Backend/.env
.env

# Qualquer outro env alternativo
*.env
*.env.local
*.env.production


# -------------------------------
# ⚙️ Configurações locais sensíveis
# -------------------------------

# Caso alguém crie config com tokens hardcoded
Backend/config/config.local.php


# -------------------------------
# 🧾 Logs
# -------------------------------

*.log
logs/
Backend/logs/


# -------------------------------
# 🗂️ Cache temporário
# -------------------------------

cache/
tmp/
*.cache


# -------------------------------
# 🖥️ Sistema operacional
# -------------------------------

# Windows
Thumbs.db
Desktop.ini

# Mac
.DS_Store

# Linux
*~


# -------------------------------
# 🧠 IDE / Editor
# -------------------------------

# VSCode
.vscode/

# JetBrains
.idea/

# Sublime
*.sublime-project
*.sublime-workspace


# -------------------------------
# 🧪 Arquivos temporários
# -------------------------------

*.swp
*.swo


# -------------------------------
# 📦 Futuro (caso use Node depois)
# -------------------------------

node_modules/
dist/
build/