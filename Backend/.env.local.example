APP_ENV=local

# API REST do GLPI no ambiente local
GLPI_URL=http://localhost/glpi/apirest.php

# Tokens do GLPI
GLPI_APP_TOKEN=seu_app_token_local
GLPI_USER_TOKEN=seu_user_token_local

# Em ambiente local com certificado interno/autossinado
GLPI_SSL_INSECURE=1

# Libera o frontend local
CORS_ORIGIN=http://localhost:3000

# Opcional: chave usada pelo assistente
OPENAI_API_KEY=sua_chave_local
